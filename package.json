{
  "name": "lemonwoo",
  "private": true,
  "version": "0.1.0",
  "description": "LemonWoo IDE v1 monorepo",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint --if-present",
    "typecheck": "pnpm -r typecheck --if-present",
    "check:branding": "bash scripts/check-branding.sh",
    "check:secrets": "bash scripts/check-secrets.sh",
    "check:licenses": "bash scripts/check-licenses.sh",
    "verify:docs": "node scripts/verify-docs-current.mjs",
    "smoke:bundle": "bash scripts/smoke-bundle.sh",
    "smoke:agent:live": "node scripts/live-agent-smoke.mjs",
    "v2:check": "bash scripts/v2-check.sh",
    "v2:gauntlet": "node scripts/v2-functional-gauntlet.mjs",
    "opencode:spike": "pnpm --filter @lemonwoo/agent-runtime build && node scripts/opencode-spike.mjs",
    "v2:web-preview-gauntlet": "node scripts/v2-web-preview-gauntlet.mjs",
    "v2:terminal-gauntlet": "node scripts/v2-terminal-gauntlet.mjs",
    "build:mac": "bash apps/desktop/build-mac.sh",
    "package:dmg": "bash scripts/package-dmg.sh",
    "release:check": "bash scripts/release-check.sh",
    "rc:check": "bash scripts/rc-check.sh",
    "rc:report": "node scripts/write-rc-report.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["opencode-ai"]
  }
}
